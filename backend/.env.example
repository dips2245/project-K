# Backend Environment Variables
PORT=5000
NODE_ENV=development

# Database (PostgreSQL) — Render provides this after creating a PostgreSQL DB
DATABASE_URL=postgresql://user:password@host:5432/bliss_nepal

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret_in_production

# WhatsApp Business Number (with country code, no +)
WHATSAPP_NUMBER=9779800000000

# Frontend URL(s) for CORS — comma-separated if multiple origins
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# SMTP Email (optional — defaults to Ethereal test in dev)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key

# Admin credentials (seeded on first run)
INITIAL_ADMIN_EMAIL=admin@blissnepal.com
INITIAL_ADMIN_PASSWORD=admin123
